{
  "info": {
    "name": "GearUp API",
    "description": "Sports & Outdoor Gear Rental Platform — full API collection covering Auth, Categories, Gear, Rentals, Payments, Reviews, and Admin.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "adminToken", "value": "" },
    { "key": "providerToken", "value": "" },
    { "key": "customerToken", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "gearId", "value": "" },
    { "key": "rentalOrderId", "value": "" },
    { "key": "paymentId", "value": "" },
    { "key": "transactionId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (Customer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Customer\",\n  \"email\": \"customer@gearup.com\",\n  \"password\": \"Customer123!\",\n  \"role\": \"CUSTOMER\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Register (Provider)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Trail Gear Co\",\n  \"email\": \"provider@gearup.com\",\n  \"password\": \"Provider123!\",\n  \"role\": \"PROVIDER\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.data && data.data.token) {",
                  "    pm.collectionVariables.set('adminToken', data.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@gearup.com\",\n  \"password\": \"Admin123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login (Provider)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.data && data.data.token) {",
                  "    pm.collectionVariables.set('providerToken', data.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"provider@gearup.com\",\n  \"password\": \"Provider123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login (Customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.data && data.data.token) {",
                  "    pm.collectionVariables.set('customerToken', data.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@gearup.com\",\n  \"password\": \"Customer123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Get Me (No Token - Error Example)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create Category (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.data && data.data.id) {",
                  "    pm.collectionVariables.set('categoryId', data.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Camping\"\n}" },
            "url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] }
          }
        },
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] }
          }
        },
        {
          "name": "Update Category (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Camping & Hiking\"\n}" },
            "url": { "raw": "{{baseUrl}}/categories/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["categories", "{{categoryId}}"] }
          }
        },
        {
          "name": "Delete Category (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/categories/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["categories", "{{categoryId}}"] }
          }
        },
        {
          "name": "Create Category - Validation Error Example",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"A\"\n}" },
            "url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] }
          }
        }
      ]
    },
    {
      "name": "Gear",
      "item": [
        {
          "name": "Create Gear (Provider)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.data && data.data.id) {",
                  "    pm.collectionVariables.set('gearId', data.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"4-Person Tent\",\n  \"description\": \"Weatherproof 4-person camping tent, easy 10-minute setup.\",\n  \"brand\": \"TrailMaster\",\n  \"pricePerDay\": 15,\n  \"stock\": 5,\n  \"images\": [\"https://placehold.co/600x400\"],\n  \"categoryId\": \"{{categoryId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/gear", "host": ["{{baseUrl}}"], "path": ["gear"] }
          }
        },
        {
          "name": "Get All Gear (with filters)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/gear?search=tent&category={{categoryId}}&minPrice=5&maxPrice=50&available=true",
              "host": ["{{baseUrl}}"],
              "path": ["gear"],
              "query": [
                { "key": "search", "value": "tent" },
                { "key": "category", "value": "{{categoryId}}" },
                { "key": "minPrice", "value": "5" },
                { "key": "maxPrice", "value": "50" },
                { "key": "available", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Get Gear By Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/gear/{{gearId}}", "host": ["{{baseUrl}}"], "path": ["gear", "{{gearId}}"] }
          }
        },
        {
          "name": "Get My Gear (Provider)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{providerToken}}" }],
            "url": { "raw": "{{baseUrl}}/gear/my-gear", "host": ["{{baseUrl}}"], "path": ["gear", "my-gear"] }
          }
        },
        {
          "name": "Update Gear (Provider, owner only)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"pricePerDay\": 18,\n  \"stock\": 8\n}" },
            "url": { "raw": "{{baseUrl}}/gear/{{gearId}}", "host": ["{{baseUrl}}"], "path": ["gear", "{{gearId}}"] }
          }
        },
        {
          "name": "Delete Gear (Provider, owner only)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{providerToken}}" }],
            "url": { "raw": "{{baseUrl}}/gear/{{gearId}}", "host": ["{{baseUrl}}"], "path": ["gear", "{{gearId}}"] }
          }
        },
        {
          "name": "Get Gear By Id - Not Found Example",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/gear/non-existent-id", "host": ["{{baseUrl}}"], "path": ["gear", "non-existent-id"] }
          }
        }
      ]
    },
    {
      "name": "Rentals",
      "item": [
        {
          "name": "Create Rental Order (Customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.data && data.data.id) {",
                  "    pm.collectionVariables.set('rentalOrderId', data.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startDate\": \"2026-08-01T00:00:00.000Z\",\n  \"endDate\": \"2026-08-04T00:00:00.000Z\",\n  \"items\": [\n    { \"gearItemId\": \"{{gearId}}\", \"quantity\": 1 }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/rentals", "host": ["{{baseUrl}}"], "path": ["rentals"] }
          }
        },
        {
          "name": "Get My Orders (Customer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": { "raw": "{{baseUrl}}/rentals/my-orders", "host": ["{{baseUrl}}"], "path": ["rentals", "my-orders"] }
          }
        },
        {
          "name": "Get Incoming Orders (Provider)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{providerToken}}" }],
            "url": { "raw": "{{baseUrl}}/rentals/incoming", "host": ["{{baseUrl}}"], "path": ["rentals", "incoming"] }
          }
        },
        {
          "name": "Get Order By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": { "raw": "{{baseUrl}}/rentals/{{rentalOrderId}}", "host": ["{{baseUrl}}"], "path": ["rentals", "{{rentalOrderId}}"] }
          }
        },
        {
          "name": "Provider Confirms Order",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"CONFIRMED\"\n}" },
            "url": { "raw": "{{baseUrl}}/rentals/{{rentalOrderId}}/status", "host": ["{{baseUrl}}"], "path": ["rentals", "{{rentalOrderId}}", "status"] }
          }
        },
        {
          "name": "Provider Marks Picked Up",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"PICKED_UP\"\n}" },
            "url": { "raw": "{{baseUrl}}/rentals/{{rentalOrderId}}/status", "host": ["{{baseUrl}}"], "path": ["rentals", "{{rentalOrderId}}", "status"] }
          }
        },
        {
          "name": "Provider Marks Returned",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"RETURNED\"\n}" },
            "url": { "raw": "{{baseUrl}}/rentals/{{rentalOrderId}}/status", "host": ["{{baseUrl}}"], "path": ["rentals", "{{rentalOrderId}}", "status"] }
          }
        },
        {
          "name": "Customer Cancels Order",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"CANCELLED\"\n}" },
            "url": { "raw": "{{baseUrl}}/rentals/{{rentalOrderId}}/status", "host": ["{{baseUrl}}"], "path": ["rentals", "{{rentalOrderId}}", "status"] }
          }
        },
        {
          "name": "Create Order - Insufficient Stock Error Example",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startDate\": \"2026-08-01T00:00:00.000Z\",\n  \"endDate\": \"2026-08-04T00:00:00.000Z\",\n  \"items\": [\n    { \"gearItemId\": \"{{gearId}}\", \"quantity\": 9999 }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/rentals", "host": ["{{baseUrl}}"], "path": ["rentals"] }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment Intent (Customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.data && data.data.payment) {",
                  "    pm.collectionVariables.set('transactionId', data.data.payment.transactionId);",
                  "    pm.collectionVariables.set('paymentId', data.data.payment.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"rentalOrderId\": \"{{rentalOrderId}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/payments/create", "host": ["{{baseUrl}}"], "path": ["payments", "create"] }
          }
        },
        {
          "name": "Confirm Payment (Customer)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"transactionId\": \"{{transactionId}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/payments/confirm", "host": ["{{baseUrl}}"], "path": ["payments", "confirm"] }
          }
        },
        {
          "name": "Get My Payments (Customer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": { "raw": "{{baseUrl}}/payments/my-payments", "host": ["{{baseUrl}}"], "path": ["payments", "my-payments"] }
          }
        },
        {
          "name": "Get Payment By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": { "raw": "{{baseUrl}}/payments/{{paymentId}}", "host": ["{{baseUrl}}"], "path": ["payments", "{{paymentId}}"] }
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review (Customer, after RETURNED order)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gearItemId\": \"{{gearId}}\",\n  \"rating\": 5,\n  \"comment\": \"Great tent, kept us dry through a storm.\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/reviews", "host": ["{{baseUrl}}"], "path": ["reviews"] }
          }
        },
        {
          "name": "Get Reviews For Gear",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/reviews/gear/{{gearId}}", "host": ["{{baseUrl}}"], "path": ["reviews", "gear", "{{gearId}}"] }
          }
        },
        {
          "name": "Create Review - Not Eligible Error Example",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gearItemId\": \"some-gear-never-rented\",\n  \"rating\": 5\n}"
            },
            "url": { "raw": "{{baseUrl}}/reviews", "host": ["{{baseUrl}}"], "path": ["reviews"] }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Users (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.data && data.data.length) {",
                  "    const customer = data.data.find(u => u.role === 'CUSTOMER');",
                  "    if (customer) pm.collectionVariables.set('userId', customer.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/admin/users", "host": ["{{baseUrl}}"], "path": ["admin", "users"] }
          }
        },
        {
          "name": "Suspend User (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"SUSPENDED\"\n}" },
            "url": { "raw": "{{baseUrl}}/admin/users/{{userId}}/status", "host": ["{{baseUrl}}"], "path": ["admin", "users", "{{userId}}", "status"] }
          }
        },
        {
          "name": "Reactivate User (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"ACTIVE\"\n}" },
            "url": { "raw": "{{baseUrl}}/admin/users/{{userId}}/status", "host": ["{{baseUrl}}"], "path": ["admin", "users", "{{userId}}", "status"] }
          }
        },
        {
          "name": "Get All Gear (Admin oversight)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/admin/gear", "host": ["{{baseUrl}}"], "path": ["admin", "gear"] }
          }
        },
        {
          "name": "Get All Rental Orders (Admin oversight)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/admin/rentals", "host": ["{{baseUrl}}"], "path": ["admin", "rentals"] }
          }
        },
        {
          "name": "Suspend User - Forbidden Example (non-admin token)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"SUSPENDED\"\n}" },
            "url": { "raw": "{{baseUrl}}/admin/users/{{userId}}/status", "host": ["{{baseUrl}}"], "path": ["admin", "users", "{{userId}}", "status"] }
          }
        }
      ]
    }
  ]
}
